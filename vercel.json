{
  "rewrites": [
    {
      "source": "/(api|storage)/:path*",
      "destination": "https://edlearnlms-production.up.railway.app/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "env": {
    "VITE_API_BASE_URL": "https://edlearnlms-production.up.railway.app"
  }
}
